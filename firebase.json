{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      { "source": "/sim-ghep-ha-noi", "destination": "/blogs/sim-ghep-ha-noi", "type": 301 },
      { "source": "/sim-ghep-da-nang", "destination": "/blogs/sim-ghep-da-nang", "type": 301 },
      { "source": "/ghep-sim-iphone-lock", "destination": "/blogs/ghep-sim-iphone-lock", "type": 301 },
      { "source": "/mua-sim-ghep", "destination": "/blogs/mua-sim-ghep", "type": 301 }
    ],
    "rewrites": [
      { "source": "/products", "destination": "/products.html" },
      { "source": "/blogs", "destination": "/blogs.html" },
      { "regex": "^/blogs/([a-zA-Z0-9_-]+)/?$", "destination": "/blogs/:1.html" },
      { "regex": "^/products/([a-zA-Z0-9_-]+)/?$", "destination": "/products/:1.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
